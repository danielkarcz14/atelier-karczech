---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Atelier Karczech | Architektura & Projekce',
  description = 'Atelier Karczech – architektonický ateliér. Navrhujeme v BIMu, od prvního náčrtu po realizaci.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-brand-950 text-white font-sans antialiased grain overflow-x-hidden">
    <slot />
    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>
