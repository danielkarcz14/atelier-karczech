---
interface Props {
  contactPerson: string;
  phone: string;
  phoneHref: string;
  email: string;
}
const { contactPerson, phone, phoneHref, email } = Astro.props;
---

<section id="kontakt" class="py-24 md:py-36 bg-brand-900/30">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
      <div class="reveal">
        <p class="text-accent text-xs font-medium tracking-[0.3em] uppercase mb-4">Kontakt</p>
        <h2 class="font-serif text-4xl md:text-6xl font-bold leading-tight mb-8">
          Pojďme to<br /><span class="italic text-accent">probrat</span>
        </h2>

        <div class="space-y-8 mt-12">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <div>
              <div class="text-[11px] tracking-[0.2em] uppercase text-brand-500 mb-1">Kontaktní osoba</div>
              <div class="text-lg font-medium">{contactPerson}</div>
            </div>
          </div>

          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div>
              <div class="text-[11px] tracking-[0.2em] uppercase text-brand-500 mb-1">Telefon</div>
              <a href={`tel:${phoneHref}`} class="text-lg font-medium hover:text-accent transition-colors">{phone}</a>
            </div>
          </div>

          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <div class="text-[11px] tracking-[0.2em] uppercase text-brand-500 mb-1">E-mail</div>
              <a href={`mailto:${email}`} class="text-lg font-medium hover:text-accent transition-colors">{email}</a>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-2">
        <div class="bg-brand-900/50 border border-brand-800/50 rounded-3xl p-8 md:p-10">
          <h3 class="font-serif text-2xl font-bold mb-8">Napište nám</h3>
          <form id="contactForm" action="/.netlify/functions/contact" method="POST" class="space-y-6" novalidate>
            <!-- Honeypot: hidden field (display:none) that humans never fill in, but bots do. -->
            <div class="hp-field" aria-hidden="true">
              <label for="_gotcha">Nevyplňovat</label>
              <input type="text" id="_gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
            </div>
            <div>
              <label for="name" class="block text-[11px] tracking-[0.2em] uppercase text-brand-500 mb-2">Jméno a příjmení</label>
              <input type="text" id="name" name="name" required class="form-input w-full px-5 py-4 rounded-xl text-white placeholder-brand-600" placeholder="Jan Novák" />
            </div>
            <div>
              <label for="email" class="block text-[11px] tracking-[0.2em] uppercase text-brand-500 mb-2">E-mail</label>
              <input type="email" id="email" name="email" required class="form-input w-full px-5 py-4 rounded-xl text-white placeholder-brand-600" placeholder="jan@email.cz" />
            </div>
            <div>
              <label for="phone" class="block text-[11px] tracking-[0.2em] uppercase text-brand-500 mb-2">Telefon</label>
              <input type="tel" id="phone" name="phone" class="form-input w-full px-5 py-4 rounded-xl text-white placeholder-brand-600" placeholder="+420 ..." />
            </div>
            <div>
              <label for="message" class="block text-[11px] tracking-[0.2em] uppercase text-brand-500 mb-2">Zpráva</label>
              <textarea id="message" name="message" rows="4" required class="form-input w-full px-5 py-4 rounded-xl text-white placeholder-brand-600 resize-none" placeholder="Popište váš záměr..."></textarea>
            </div>
            <button type="submit" class="btn-primary w-full bg-accent text-brand-950 py-4 rounded-xl font-semibold text-sm tracking-wide uppercase hover:text-brand-950 transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
              Odeslat zprávu
            </button>
            <p id="formStatus" class="form-status" role="status" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
