---
// Static content; the visualization is a placeholder for future BIM imagery.
---

<section id="bim" class="py-24 md:py-36 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-1/2 h-full bg-accent/[0.03] rounded-l-[4rem] hidden lg:block"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="reveal">
        <p class="text-accent text-xs font-medium tracking-[0.3em] uppercase mb-4">Technologie</p>
        <h2 class="font-serif text-4xl md:text-6xl font-bold leading-tight mb-6">
          Pracujeme<br />v <span class="italic text-accent">BIMu</span>
        </h2>
        <p class="text-brand-300 text-lg font-light leading-relaxed mb-10 max-w-md">
          Navrhujeme v BIMu. Díky tomu máme pod kontrolou každý detail – od prvního náčrtu po realizaci.
        </p>
        <div class="grid grid-cols-3 gap-8">
          <div>
            <div class="counter text-4xl font-serif font-bold text-accent" data-target="100">0</div>
            <div class="text-[11px] tracking-[0.2em] uppercase text-brand-500 mt-2">% digitální</div>
          </div>
          <div>
            <div class="text-4xl font-serif font-bold text-accent">3D</div>
            <div class="text-[11px] tracking-[0.2em] uppercase text-brand-500 mt-2">Koordinace</div>
          </div>
          <div>
            <div class="text-4xl font-serif font-bold text-accent">LOD</div>
            <div class="text-[11px] tracking-[0.2em] uppercase text-brand-500 mt-2">Detailní model</div>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-2">
        <div class="bg-brand-900/50 border border-brand-800/50 rounded-3xl aspect-[4/3] flex items-center justify-center relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-accent/5 to-transparent"></div>
          <div class="relative text-center p-12">
            <div class="w-20 h-20 mx-auto rounded-full border border-accent/20 flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-accent/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
              </svg>
            </div>
            <p class="text-brand-400 font-serif text-lg">BIM vizualizace</p>
            <p class="text-brand-600 text-sm mt-2 font-light">Brzy doplníme</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
