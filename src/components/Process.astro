---
interface Step {
  number: string;
  title: string;
  body: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---

<section id="proces" class="py-24 md:py-36">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
      <div class="lg:sticky lg:top-32 lg:self-start">
        <div class="reveal">
          <p class="text-accent text-xs font-medium tracking-[0.3em] uppercase mb-4">Průvodce spoluprací</p>
          <h2 class="font-serif text-4xl md:text-6xl font-bold leading-tight mb-6">
            Jak to u nás<br /><span class="italic text-accent">funguje</span>
          </h2>
          <p class="text-brand-400 font-light leading-relaxed max-w-md">
            Od prvního setkání až po hotovou stavbu vás provedeme každým krokem. Transparentně, profesionálně a vždy s ohledem na váš záměr.
          </p>
          <a href="#kontakt" class="btn-primary inline-block bg-accent text-brand-950 px-8 py-4 rounded-full font-semibold text-sm tracking-wide uppercase mt-10 hover:text-brand-950 transition-colors">
            Začít spolupráci
          </a>
        </div>
      </div>

      <div class="space-y-12">
        {
          steps.map((step, i) => (
            <div class="step-card relative pl-20">
              {i < steps.length - 1 && <div class="step-line-v"></div>}
              <div class="absolute left-0 top-0 w-16 h-16 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center">
                <span class="step-number font-serif text-2xl font-bold text-accent">{step.number}</span>
              </div>
              <h3 class="font-serif text-2xl font-bold mb-3">{step.title}</h3>
              <p class="text-brand-400 font-light leading-relaxed">{step.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
