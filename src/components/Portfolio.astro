---
interface Item {
  title: string;
  category: string;
  image: string;
  imageFull: string;
  alt?: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<section id="portfolio" class="py-24 md:py-36">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 reveal">
      <div>
        <p class="text-accent text-xs font-medium tracking-[0.3em] uppercase mb-4">Vybrané projekty</p>
        <h2 class="font-serif text-4xl md:text-6xl font-bold leading-tight">Naše <span class="italic text-accent">práce</span></h2>
      </div>
      <p class="text-brand-400 text-sm max-w-sm font-light leading-relaxed">Každý projekt je originální odpovědí na místo, kontext a přání klienta.</p>
    </div>
  </div>

  <div class="portfolio-wrapper">
    <button type="button" id="portfolioPrev" class="portfolio-arrow prev is-hidden" aria-label="Předchozí projekty">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>

    <button type="button" id="portfolioNext" class="portfolio-arrow next" aria-label="Další projekty">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>

    <div class="portfolio-track px-6 lg:px-12" id="portfolioTrack">
      {
        items.map((item) => (
          <div
            class="portfolio-card w-[85vw] md:w-[55vw] lg:w-[40vw] rounded-2xl overflow-hidden relative cursor-pointer"
            data-full={item.imageFull}
          >
            <div class="aspect-[16/10]">
              <img src={item.image} alt={item.alt ?? item.title} class="w-full h-full object-cover" loading="lazy" decoding="async" />
            </div>
            <div class="portfolio-overlay absolute inset-0 flex items-end p-8">
              <div>
                <h3 class="font-serif text-xl font-bold text-white">{item.title}</h3>
                <p class="text-brand-300 text-sm mt-1">{item.category}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 mt-8 flex items-center gap-3">
    <div class="h-px flex-1 bg-brand-800/50"></div>
    <span class="text-[10px] tracking-[0.3em] uppercase text-brand-500">Táhněte pro další</span>
    <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </svg>
  </div>
</section>
