---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

import Layout from '../layouts/Layout.astro';
import Cursor from '../components/Cursor.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Portfolio from '../components/Portfolio.astro';
import Process from '../components/Process.astro';
import Bim from '../components/Bim.astro';
import Team from '../components/Team.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

const reader = createReader(process.cwd(), keystaticConfig);

const settings = await reader.singletons.settings.read();

const byOrder = (a: { entry: { order: number } }, b: { entry: { order: number } }) =>
  a.entry.order - b.entry.order;

// Keystatic stores only the filename for image fields, so prepend the public path.
const img = (file: string | null, base = '/images/') => (file ? `${base}${file}` : '');

const portfolioItems = (await reader.collections.portfolio.all())
  .sort(byOrder)
  .map(({ entry }) => ({
    title: entry.title,
    category: entry.category,
    image: img(entry.image),
    imageFull: img(entry.imageFull),
    alt: entry.alt,
  }));

const teamMembers = (await reader.collections.team.all())
  .sort(byOrder)
  .map(({ entry }) => ({
    name: entry.name,
    role: entry.role,
    photo: entry.photo ? img(entry.photo, '/images/team/') : null,
  }));

const processSteps = (await reader.collections.process.all())
  .sort(byOrder)
  .map(({ entry }) => ({
    number: entry.number,
    title: entry.title,
    body: entry.body,
  }));

const bimRenders = (await reader.collections.bim.all())
  .sort(byOrder)
  .map(({ entry }) => ({
    title: entry.title,
    image: img(entry.image),
    imageFull: img(entry.imageFull),
    alt: entry.alt,
  }));

// Fallbacks in case the settings singleton is missing.
const heroTitlePlain = settings?.heroTitlePlain ?? 'Navrhujeme prostory,';
const heroTitleAccent = settings?.heroTitleAccent ?? 've kterých chcete žít.';
const heroSubtitle =
  settings?.heroSubtitle ??
  'Od prvního setkání až po realizaci. Každý projekt řešíme s důrazem na detail, funkci a vaši spokojenost.';
const contactPerson = settings?.contactPerson ?? 'Bc. Filip Karcz';
const contactPhone = settings?.contactPhone ?? '732 993 086';
const contactPhoneHref = settings?.contactPhoneHref ?? '+420732993086';
const contactEmail = settings?.contactEmail ?? 'karcz@atelierkarczech.cz';
---

<Layout>
  <Cursor />
  <Navbar phone={contactPhone} phoneHref={contactPhoneHref} email={contactEmail} />

  <Hero titlePlain={heroTitlePlain} titleAccent={heroTitleAccent} subtitle={heroSubtitle} />

  <Marquee />

  <Portfolio items={portfolioItems} />
  <div class="section-divider max-w-7xl mx-auto"></div>

  <Process steps={processSteps} />
  <div class="section-divider max-w-7xl mx-auto"></div>

  <Bim renders={bimRenders} />
  <div class="section-divider max-w-7xl mx-auto"></div>

  <Team members={teamMembers} />

  <CtaBanner />

  <Contact
    contactPerson={contactPerson}
    phone={contactPhone}
    phoneHref={contactPhoneHref}
    email={contactEmail}
  />

  <Footer />

  <Lightbox />
</Layout>
